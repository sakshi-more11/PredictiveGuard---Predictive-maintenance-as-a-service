# API
API_TITLE=PredictiveGuard
API_VERSION=1.0.0
DEBUG=True
WORKERS=4

# Database
DATABASE_URL=postgresql://postgres:password@postgres:5432/predictive_guard
DB_HOST=postgres
DB_PORT=5432
DB_NAME=predictive_guard
DB_USER=postgres
DB_PASSWORD=password

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Storage
STORAGE_TYPE=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=predictive-guard
UPLOAD_FOLDER=./data/uploads

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=8001

# ML Models
MODEL_REGISTRY_PATH=./models/registry
ARTIFACT_STORAGE_PATH=./models/artifacts
METRICS_STORAGE_PATH=./models/metrics

# Alerts
WEBHOOK_TIMEOUT=30
ALERT_CHECK_INTERVAL=300